---
import piscina from '../../assets/pages/home/torre-de-mejanell-piscina.webp';
import casa from '../../assets/pages/home/torre-de-mejanell.webp';

const slides = [
	{
		src: piscina,
		label: 'Piscina',
		title: 'Agua tranquila y luz abierta',
		description: 'La imagen que dejamos de momento como referencia principal para el home.',
	},
	{
		src: casa,
		label: 'Casa',
		title: 'La torre y el entorno',
		description: 'Segunda foto para darle continuidad visual al slider del home.',
	},
];
---

<section class="mx-auto max-w-7xl px-4 pb-8 lg:px-6 lg:pb-12">
	<div class="relative overflow-hidden rounded-[2rem] border border-black/10 bg-white/70 shadow-[0_30px_90px_rgba(18,25,26,0.12)]">
		<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(239,180,108,0.18),transparent_42%)]"></div>

		<div class="flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth px-4 py-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
			{slides.map((slide, index) => (
				<article class="min-w-full snap-center overflow-hidden rounded-[1.6rem] bg-[#1f1a17] text-white shadow-lg">
					<div class="grid lg:grid-cols-[1.15fr_0.85fr]">
						<div class="relative min-h-[320px] lg:min-h-[520px]">
							<img src={slide.src.src} alt={slide.title} class="absolute inset-0 h-full w-full object-cover" loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />
						</div>
						<div class="flex flex-col justify-between gap-8 p-6 lg:p-8">
							<div>
								<p class="text-xs font-bold uppercase tracking-[0.2em] text-white/60">{slide.label}</p>
								<h3 class="mt-4 max-w-[10ch] text-4xl leading-[0.95] tracking-[-0.04em] lg:text-5xl">{slide.title}</h3>
								<p class="mt-4 max-w-md text-base leading-7 text-white/70">{slide.description}</p>
							</div>

							<div class="flex items-center justify-between gap-3 border-t border-white/10 pt-5 text-sm text-white/60">
								<span>0{index + 1}</span>
								<span>Desliza para ver más</span>
							</div>
						</div>
					</div>
				</article>
			))}
		</div>
	</div>
</section>
