---
import { Image } from 'astro:assets';
import antigaMasia from '../../assets/pages/home/dibuix-torre.webp';
import casaRural from '../../assets/pages/home/castell-mejanell-aerea.webp';

const { room } = Astro.props;
---

<section id="evolucion" class="mx-auto max-w-7xl px-4 py-16 lg:px-6 lg:py-24">
  <div class="max-w-4xl mx-auto text-center mb-16">
     <h2 class="mx-auto max-w-5xl text-center text-4xl leading-[1.1] tracking-[-0.04em] text-[#1f1a17] sm:text-5xl lg:text-[4.4rem]">
        Una antiga masia transformada en un refugi de turisme rural on els somnis es barregen amb l'encant de la natura.
    </h2>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-2 items-center max-w-xl lg:max-w-6xl mx-auto">
    
    <div class="lg:col-span-5 flex flex-col items-center text-center z-10">
      <span class="mb-4 text-base leading-7 text-[#6b5f56]">Des del segle XI</span>
      <div class="w-full">
        <Image
          src={antigaMasia}
          alt="Antiga Masia 1850"
          class="w-full h-auto object-contain grayscale contrast-125"
        />
      </div>
    </div>

    <div class="lg:col-span-2 flex flex-col items-center justify-center py-2 lg:py-0 -my-8 lg:my-0 -mx-6 lg:-mx-12 z-20 pointer-events-none">
      <div class="w-full overflow-visible">
        
        <svg class="w-full h-24 lg:h-20 overflow-visible" viewBox="0 0 200 150" fill="none">
          <defs>
            <marker 
              id="punta-perfecta" 
              viewBox="0 0 10 10" 
              refX="6" 
              refY="5" 
              markerWidth="6" 
              markerHeight="6" 
              orient="auto-start-reverse"
            >
              <path d="M 1,2 L 7,5 L 1,8" stroke="#7a5a3d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </marker>
          </defs>

          <path
            id="camino-escritorio"
            class="hidden lg:block"
            d="M -20,20 C 60,20 140,80 220,80"
            stroke="#7a5a3d"
            stroke-width="3"
            stroke-linecap="round"
          />

          <path
            id="camino-movil"
            class="block lg:hidden"
            d="M 100, -15 C 50,40 150,90 100,165"
            stroke="#7a5a3d"
            stroke-width="3"
            stroke-linecap="round"
          />
        </svg>
        
      </div>
    </div>

    <div id="contenedor-presente" class="lg:col-span-5 flex flex-col items-center text-center lg:translate-y-12 opacity-0 z-10">
      <div class="w-full [mask-image:radial-gradient(ellipse_at_center,black_65%,transparent_98%)] [-webkit-mask-image:radial-gradient(ellipse_at_center,black_65%,transparent_98%)] drop-shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
        <Image
          src={casaRural}
          alt="Casa Rural"
          class="w-full h-auto object-contain scale-105"
        />
      </div>
      <span class="mt-3 text-base leading-7 text-[#6b5f56]">Avui en dia</span>
    </div>

  </div>
</section>

<script>
  import { animate, inView } from "motion";

  if (typeof window !== "undefined") {
    inView("#evolucion", () => {
      const esEscritorio = window.innerWidth >= 1024;

      const camino = document.getElementById(esEscritorio ? 'camino-escritorio' : 'camino-movil') as SVGPathElement | null;
      const destino = document.getElementById('contenedor-presente') as HTMLElement | null;

      if (camino && destino) {
        const longitudCamino = camino.getTotalLength();
        
        camino.setAttribute("stroke-dasharray", longitudCamino.toString());
        camino.setAttribute("stroke-dashoffset", longitudCamino.toString());

        // Añadido 'as any' en las opciones para aceptar el string del easing
        const animarLinea = animate(
          camino,
          { strokeDashoffset: 0 } as any,
          { duration: 1.6, easing: "ease-in-out" } as any
        );

        animarLinea.finished.then(() => {
          camino.setAttribute("marker-end", "url(#punta-perfecta)");

          const desplazamientoY = esEscritorio ? 48 : 0;

          // Añadido 'as any' tanto en las propiedades como en las opciones
          animate(
            destino, 
            { opacity: 1, y: [desplazamientoY + 20, desplazamientoY] } as any, 
            { duration: 0.8, easing: "ease-out" } as any
          );
        });
      }
    }, { margin: "-20% 0px -20% 0px" });
  }
</script>