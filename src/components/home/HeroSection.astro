---
import { Image } from 'astro:assets';

// Cargamos todas las imágenes de la carpeta hero
const images = import.meta.glob<{ default: ImageMetadata }>('../../assets/pages/hero/*.{jpeg,jpg,png,webp}');
const imageEntries = Object.entries(images);
---

<section id="top" class="relative min-h-screen overflow-hidden text-white">
    <!-- Contenedor de imágenes (Slider) -->
    <div class="absolute inset-0 z-0">
        {imageEntries.map(([path, imageLoader], index) => (
            <div 
                class={`hero-slide absolute inset-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                data-index={index}
            >
                <Image 
                    src={imageLoader()} 
                    alt="Castell de Mejanell" 
                    class="h-full w-full object-cover" 
                    widths={[640, 1024, 1920]}
                    sizes="100vw"
                    quality={75}
                    fetchpriority={index === 0 ? "high" : "low"}
                    loading={index === 0 ? "eager" : "lazy"}
                />
                <div class="absolute inset-0 bg-black/20"></div>
                <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.20)_0%,rgba(0,0,0,0.42)_100%)]"></div>
            </div>
        ))}
    </div>

    <!-- Contenido -->
    <div class="relative z-10 mx-auto flex min-h-screen max-w-7xl flex-col px-4 pb-10 pt-24 lg:px-6 lg:pt-28">
        <div class="mx-auto mt-30 w-full max-w-5xl text-center">
            <p id="hero-subtitle" class="mb-4 text-[0.7rem] font-semibold uppercase tracking-[0.34em] text-white/80 opacity-0">
                Castell de Mejanell
            </p>
            <h1 id="hero-title" class="mx-auto max-w-[14ch] font-serif text-[clamp(3.6rem,8vw,7rem)] leading-[0.9] tracking-[-0.04em] text-white opacity-0">
                Benvinguts a la Torre de Mejanell
            </h1>
            <p id="hero-description" class="mx-auto mt-5 max-w-2xl text-[clamp(1.05rem,1.7vw,1.35rem)] leading-8 text-white/85 opacity-0">
                Escapa't a a un paradís rural amb molta historia
            </p>
        </div>

        <div id="hero-buttons" class="mt-8 flex flex-wrap items-center justify-center gap-3 opacity-0">
            <a class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-5 py-3 text-sm font-bold text-white backdrop-blur-md transition-transform duration-200 hover:-translate-y-0.5 hover:bg-white/15" href="#estancias">Explorar habitacions</a>
            <a class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-5 py-3 text-sm font-bold text-white backdrop-blur-md transition-transform duration-200 hover:-translate-y-0.5 hover:bg-white/15" href="/preus-i-ocupacio">Preus i ocupació</a>
        </div>
    </div>
</section>

<script>
    async function initHero() {
        // Carga dinámica de motion para no bloquear el inicio
        const { animate } = await import("motion");
        
        // Animaciones de entrada
        const targets = ["#hero-subtitle", "#hero-title", "#hero-description", "#hero-buttons"];
        targets.forEach((selector, i) => {
            animate(selector, { opacity: [0, 1], y: [20, 0] }, { duration: 0.8, delay: i * 0.15, easing: "ease-out" });
        });

        // Slider logic
        const slides = document.querySelectorAll('.hero-slide');
        if (slides.length > 1) {
            let currentIndex = 0;
            setInterval(() => {
                slides[currentIndex].classList.replace('opacity-100', 'opacity-0');
                currentIndex = (currentIndex + 1) % slides.length;
                slides[currentIndex].classList.replace('opacity-0', 'opacity-100');
            }, 5000);
        }
    }

    // Ejecución optimizada al quedar libre el navegador
    if ('requestIdleCallback' in window) {
        requestIdleCallback(initHero);
    } else {
        setTimeout(initHero, 1);
    }
</script>