---
import { Image } from 'astro:assets';

// 1. Definimos los tipos permitidos para el idioma de forma estricta
interface Props {
    lang?: 'ca' | 'es' | 'en';
}

// 2. Asignamos un valor por defecto seguro
const { lang = 'ca' } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>('../../assets/pages/rooms/*.{jpeg,jpg,png,gif,webp}');

const rooms = [
    {
        title: 'Habitació 3 persones',
        text: 'Habitació de dos llits individuals amb bressol i lavabo. ',
        image: '../../assets/pages/rooms/torre-mejanell-3-persones.webp',
    },
    {
        title: 'Habitació doble',
        text: 'Habitació a la planta baixa amb llit de matrimoni per a dues persones.',
        image: '../../assets/pages/rooms/torre-mejanell-doble2.webp',
    },
    {
        title: 'Habitació 2 persones',
        text: 'Habitació a la planta baixa amb llit de matrimoni per a dues persones. ',
        image: '../../assets/pages/rooms/torre-mejanell-2-persones3.webp',
    },
];

// 3. Tipamos el objeto indicando que las claves son fijas ('ca', 'es', 'en')
const localizedPaths: Record<'ca' | 'es' | 'en', string> = {
    ca: '/habitacions',
    es: '/es/habitaciones',
    en: '/en/rooms'
};

const buttonLabels: Record<'ca' | 'es' | 'en', string> = {
    ca: 'Veure més habitacions',
    es: 'Ver más habitaciones',
    en: 'View all rooms'
};

const featuredRooms = rooms.slice(0, 3);
---

<section id="estancias" class="mx-auto max-w-7xl px-4 py-16 lg:px-6 lg:py-24 overflow-hidden">
    <div class="max-w-4xl mx-auto text-center">
        <p id="room-title" class="mb-4 text-sm font-extrabold uppercase tracking-[0.22em] text-[#7a5a3d] opacity-0">
            Elegància, calma, exclusivitat
        </p>
        <h2 id="room-heading" class="max-w-[14ch] mx-auto text-4xl leading-[0.95] tracking-[-0.04em] text-[#1f1a17] sm:text-5xl lg:text-[4.4rem] opacity-0">
            {lang === 'es' ? 'Habitaciones' : lang === 'en' ? 'Our Rooms' : 'Habitacions'}
        </h2>
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-12">
        {featuredRooms.map((room) => {
            if (!images[room.image]) {
                throw new Error(`"${room.image}" no existeix o la ruta està mal escrita.`);
            }

            return (
                <article class="room-card opacity-0 relative overflow-hidden rounded-[1.75rem] border border-black/10 bg-white/75 shadow-[0_16px_42px_rgba(39,29,22,0.08)] transition-transform duration-200 hover:-translate-y-2 lg:col-span-4">
                    <div class="w-full">
                        <Image
                            src={images[room.image]()}
                            alt={room.title}
                            width={800}  
                            height={600} 
                            class="w-full h-auto object-contain contrast-125"
                        />
                    </div>
                    
                    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.4),transparent_42%)]"></div>
                    
                    <div class="p-5">
                        <h3 class="mt-2 text-3xl leading-none tracking-[-0.03em] text-[#1f1a17]">{room.title}</h3>
                        <p class="mt-3 text-base leading-7 text-[#6b5f56]">{room.text}</p>
                    </div>
                </article>
            );
        })}
    </div>

    <div class="mt-12 text-center">
        <a 
            id="room-btn"
            href={localizedPaths[lang]} 
            class="inline-flex items-center justify-center rounded-full text-xs px-6 py-3 sm:text-sm font-bold border border-[#1f1a17] bg-[#1f1a17] !text-[#f8f4ec] transition-all duration-200 hover:bg-[#332c28] hover:-translate-y-0.5 shadow-md opacity-0"
        >
            {buttonLabels[lang]}
        </a>
    </div>
</section>

<script>
    import { animate, inView, stagger, cubicBezier } from "motion";

    // Un easing rústico, fluido y elegante
    const transitionEase = cubicBezier(0.25, 1, 0.5, 1);

    if (typeof window !== "undefined") {
        // Animació de la capçalera (títol i subtítol)
        inView("#estancias", () => {
            animate("#room-title", { opacity: [0, 1], y: [20, 0] } as any, { duration: 0.6, easing: transitionEase } as any);
            animate("#room-heading", { opacity: [0, 1], y: [30, 0] } as any, { duration: 0.8, delay: 0.15, easing: transitionEase } as any);
        }, { margin: "0px 0px -10% 0px" });

        // Animació seqüencial de les targetes (cards)
        inView(".room-card", () => {
            animate(".room-card", { 
                opacity: [0, 1], 
                y: [40, 0] // Cambiado 'transform' por 'y' que es más limpio para Motion y con el casting 'as any'
            } as any, { 
                delay: stagger(0.15),
                duration: 0.7, 
                easing: transitionEase
            } as any);

            // Animació del botó de sota
            animate("#room-btn", { opacity: [0, 1], y: [20, 0] } as any, { duration: 0.5, delay: 0.5, easing: transitionEase } as any);
        }, { margin: "0px 0px -15% 0px" });
    }
</script>