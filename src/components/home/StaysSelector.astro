---
import { Image } from 'astro:assets';

interface Props {
    lang?: 'ca' | 'es' | 'en';
}

const { lang = 'ca' } = Astro.props;

// Cambiamos el glob a 'eager: true' para resolver las imágenes en el servidor inmediatamente
const images = import.meta.glob<{ default: ImageMetadata }>('../../assets/pages/rooms/*.{jpeg,jpg,png,gif,webp}', { eager: true });

const rawRooms = [
    {
        title: 'Habitació 3 persones',
        text: 'Habitació de dos llits individuals amb bressol i lavabo.',
        image: '../../assets/pages/rooms/torre-mejanell-3-persones.webp',
        gallery: [
            '../../assets/pages/rooms/torre-mejanell-3-persones.webp',
            '../../assets/pages/rooms/torre-mejanell-doble2.webp',
            '../../assets/pages/rooms/torre-mejanell-2-persones3.webp'
        ]
    },
    {
        title: 'Habitació doble',
        text: 'Habitació a la planta baixa amb llit de matrimoni.',
        image: '../../assets/pages/rooms/torre-mejanell-doble2.webp',
        gallery: [
            '../../assets/pages/rooms/torre-mejanell-doble2.webp',
            '../../assets/pages/rooms/torre-mejanell-doble1.webp'
        ]
    },
    {
        title: 'Habitació 2 persones',
        text: 'Llit de matrimoni',
        image: '../../assets/pages/rooms/torre-mejanell-2-persones3.webp',
        gallery: ['../../assets/pages/rooms/torre-mejanell-2-persones3.webp']
    },
    {
        title: 'Habitació 2 persones',
        text: 'Dos llits individuals amb lavabo',
        image: '../../assets/pages/rooms/torre-mejanell-2-persones4.webp',
        gallery: ['../../assets/pages/rooms/torre-mejanell-2-persones4.webp']
    },
    {
        title: 'Habitació doble',
        text: 'Habitació a la planta baixa per a dues persones.',
        image: '../../assets/pages/rooms/torre-mejanell-doble1.webp',
        gallery: ['../../assets/pages/rooms/torre-mejanell-doble1.webp']
    },
    {
        title: 'Habitació 2 persones',
        text: 'Dos llits individuals',
        image: '../../assets/pages/rooms/torre-mejanell-2-persones.webp',
        gallery: ['../../assets/pages/rooms/torre-mejanell-2-persones.webp']
    },
];

// Procesamos las habitaciones en el servidor para convertir los strings de ruta en URLs web finales (.src)
const rooms = rawRooms.map(room => {
    const resolvedGalleryUrls = room.gallery
        .map(path => images[path]?.default?.src) // Extrae la URL final procesada por Astro/Vite
        .filter(Boolean); // Elimina rutas que no existan o estén mal escritas

    return {
        ...room,
        resolvedGallery: resolvedGalleryUrls
    };
});
---

<section id="habitacions-visor" class="mx-auto max-w-7xl px-4 py-16 lg:px-6 lg:py-24">
    <div class="flex flex-col-reverse md:flex-row md:grid md:grid-cols-12 gap-8 bg-white border border-[#e5dcd0] rounded-[2rem] shadow-xl overflow-hidden p-4 md:p-6 lg:p-8">
        
        <div class="room-nav md:col-span-4 w-full h-full md:border-r border-[#e5dcd0] md:pr-4">
            <div class="flex flex-row md:flex-col space-x-2 md:space-x-0 md:space-y-3 overflow-x-auto md:overflow-x-visible pb-4 md:pb-0 scrollbar-none snap-x snap-mandatory">
                {rooms.map((room, index) => (
                    <button 
                        class:list={[
                            "room-nav-btn w-full text-left p-4 md:p-5 rounded-xl md:rounded-2xl transition-all duration-300 ease-out flex items-center justify-between group snap-center whitespace-nowrap md:whitespace-normal",
                            index === 0 ? "active bg-[#1f1a17] text-[#f4efe9] shadow-md" : "text-[#1f1a17] hover:bg-[#f6efe4]"
                        ]}
                        data-index={index}
                    >
                        <span class="font-medium text-base md:text-lg tracking-tight">{room.title}</span>
                        <svg class:list={["w-5 h-5 transition-transform duration-300 ml-3", index === 0 ? "translate-x-1" : "group-hover:translate-x-1"]} viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                        </svg>
                    </button>
                ))}
            </div>
        </div>

        <div class="room-viewer md:col-span-8 relative h-[450px] md:h-[600px] overflow-hidden rounded-[2rem] border border-[#e5dcd0]">
            {rooms.map((room, index) => {
                if (!images[room.image]) return null;

                return (
                    <div id={`room-panel-${index}`} class:list={["absolute inset-0 w-full h-full room-panel transition-opacity duration-700 ease-in-out", index === 0 ? "opacity-100 z-10" : "opacity-0 z-0"]}>
                        <Image
                                src={images[room.image].default}
                                alt={room.title}
                                width={1200}
                                height={800}
                                class="absolute inset-0 w-full h-full object-cover brightness-[0.85] contrast-[1.1]"
                                loading={index === 0 ? "eager" : "lazy"}
                            />
                        <div class="absolute inset-0 bg-gradient-to-t from-[#1f1a17]/90 via-[#1f1a17]/30 to-transparent"></div>
                        <div class="absolute bottom-0 left-0 p-8 md:p-12 text-white z-20 w-full">
                            <h3 class="text-4xl md:text-5xl font-serif mb-3 tracking-tight">{room.title}</h3>
                            <p class="text-[#d1ccc6] max-w-xl text-lg font-light leading-relaxed">{room.text}</p>
                            
                            {/* Pasamos el array ya resuelto con las URLs web listas para usar */}
                            <button 
                                class="open-gallery-btn inline-block mt-6 text-xs uppercase tracking-[0.2em] font-bold text-[#c5a073] border-b border-[#c5a073] pb-1 hover:text-white hover:border-white transition-colors duration-300 cursor-pointer"
                                data-gallery={JSON.stringify(room.resolvedGallery)}
                            >
                                Veure galeria completa
                            </button>
                        </div>
                    </div>
                );
            })}
        </div>
    </div>
</section>

<style>
    .scrollbar-none::-webkit-scrollbar { display: none; }
    .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
    import { animate, cubicBezier } from "motion";

    const premiumEase = cubicBezier(0.16, 1, 0.3, 1);
    const autoplayDelay = 5000;

    if (typeof window !== "undefined") {
        const visor = document.getElementById("habitacions-visor");
        
        if (!visor) {
            throw new Error("No se ha encontrado el elemento #habitacions-visor");
        }

        const navContainer = visor.querySelector(".room-nav div") as HTMLElement | null;
        const navButtons = visor.querySelectorAll(".room-nav-btn") as NodeListOf<HTMLButtonElement>;
        const panels = visor.querySelectorAll(".room-panel") as NodeListOf<HTMLElement>;
        
        let currentIndex = 0;
        let autoplayInterval: ReturnType<typeof setInterval> | undefined;

        const updateNavScroll = (index: number) => {
            if (window.innerWidth < 768 && navContainer) {
                const btn = navButtons[index];
                if (!btn) return;

                const btnOffset = btn.offsetLeft;
                const containerWidth = navContainer.offsetWidth;
                const btnWidth = btn.offsetWidth;
                const scrollLeft = btnOffset - (containerWidth / 2) + (btnWidth / 2);
                
                navContainer.scrollTo({ left: scrollLeft, behavior: 'smooth' });
            }
        };

        const showRoom = (index: number) => {
            const currentPanel = panels[currentIndex];
            const nextPanel = panels[index];
            const currentBtn = navButtons[currentIndex];
            const nextBtn = navButtons[index];
            
            if (!currentPanel || !nextPanel || !currentBtn || !nextBtn || currentPanel === nextPanel) return;

            // Clases del botón previo
            currentBtn.classList.remove("active", "bg-[#1f1a17]", "text-[#f4efe9]", "shadow-md");
            currentBtn.classList.add("text-[#1f1a17]", "hover:bg-[#f6efe4]");
            currentBtn.querySelector("svg")?.classList.remove("translate-x-1");

            // Clases del nuevo botón
            nextBtn.classList.add("active", "bg-[#1f1a17]", "text-[#f4efe9]", "shadow-md");
            nextBtn.classList.remove("text-[#1f1a17]", "hover:bg-[#f6efe4]");
            nextBtn.querySelector("svg")?.classList.add("translate-x-1");

            // Animaciones forzando 'as any' tanto en las propiedades como en las opciones (duration/easing)
            animate(
                currentPanel, 
                { opacity: 0 } as any, 
                { duration: 0.7, easing: premiumEase } as any
            );
            currentPanel.style.zIndex = "0";

            animate(
                nextPanel, 
                { opacity: 1 } as any, 
                { duration: 0.9, easing: premiumEase } as any
            );
            nextPanel.style.zIndex = "10";

            updateNavScroll(index);
            currentIndex = index;
        };

        const nextRoom = () => {
            if (navButtons.length === 0) return;
            let nextIndex = (currentIndex + 1) % navButtons.length;
            showRoom(nextIndex);
        };

        const startAutoplay = () => { 
            autoplayInterval = setInterval(nextRoom, autoplayDelay); 
        };
        
        const stopAutoplay = () => { 
            if (autoplayInterval) clearInterval(autoplayInterval); 
        };

        navButtons.forEach((btn) => {
            btn.addEventListener("click", () => {
                stopAutoplay();
                const dataIndex = btn.getAttribute("data-index");
                if (dataIndex) {
                    const index = parseInt(dataIndex, 10);
                    showRoom(index);
                }
                startAutoplay();
            });
        });

        visor.querySelectorAll('.open-gallery-btn').forEach((btn) => {
            btn.addEventListener('click', stopAutoplay);
        });

        startAutoplay();
    }
</script>