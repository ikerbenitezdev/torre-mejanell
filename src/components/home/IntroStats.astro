---
import basicImage1 from '../../assets/pages/home/exterior-torre-mejanell.webp';
import basicImage2 from '../../assets/pages/home/escales-torre-mejanell.webp';

const metrics = [
	{ value: '04', label: 'capas visuales' },
	{ value: '12', label: 'bloques animados' },
	{ value: '100%', label: 'estatica y ligera' },
];
---

<section class="mx-auto max-w-7xl px-4 py-16">
    <h2 class="mx-auto max-w-5xl text-center text-4xl leading-[1.1] tracking-[-0.04em] text-[#1f1a17] sm:text-5xl lg:text-[4.4rem]">
        Una antiga masia transformada en un refugi de turisme rural on els somnis es barregen amb l'encant de la natura.
    </h2>

    <div class="mt-12 grid gap-8 sm:grid-cols-2">
        <div class="overflow-hidden rounded-lg">
            <img 
                src={basicImage1.src}
                alt="Escala de caragol de pedra a la masia" 
                class="h-[500px] w-full object-cover sm:h-[600px] lg:h-[700px]"
            />
        </div>

        <div class="overflow-hidden rounded-lg">
            <img 
                src={basicImage2.src}
                alt="Exterior de la masia de turisme rural amb torre de pedra" 
                class="h-[500px] w-full object-cover sm:h-[600px] lg:h-[700px]"
            />
        </div>
    </div>

    </section>
