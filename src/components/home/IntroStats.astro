---
const metrics = [
	{ value: '04', label: 'capas visuales' },
	{ value: '12', label: 'bloques animados' },
	{ value: '100%', label: 'estatica y ligera' },
];
---

<section class="mx-auto grid max-w-7xl gap-8 px-4 py-16 lg:grid-cols-[1fr_auto] lg:px-6 lg:py-24">
	<div class="max-w-3xl">
		<p class="mb-4 text-sm font-extrabold uppercase tracking-[0.22em] text-[#7a5a3d]">Direccion de arte</p>
		<h2 class="max-w-[13ch] text-4xl leading-[0.95] tracking-[-0.04em] text-[#1f1a17] sm:text-5xl lg:text-[4.4rem]">
			Una base limpia para crecer con galerias, historias y bloques mas complejos.
		</h2>
	</div>
	<div class="grid gap-4 sm:grid-cols-3 lg:w-[42rem]">
		{metrics.map((metric) => (
			<article class="rounded-[1.5rem] border border-black/10 bg-white/70 p-5 shadow-[0_16px_42px_rgba(39,29,22,0.08)]">
				<strong class="block text-4xl leading-none tracking-[-0.04em] text-[#1f1a17]">{metric.value}</strong>
				<span class="mt-2 block text-sm leading-6 text-[#6b5f56]">{metric.label}</span>
			</article>
		))}
	</div>
</section>
