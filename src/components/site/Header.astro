---
const { lang = 'ca', slug = '' } = Astro.props as {
    lang?: 'ca' | 'es' | 'en';
    slug?: string;
};

import logo from '../../assets/logo-torre-mejanell-blanc.svg';
import logoNegre from '../../assets/logo-torre-mejanell-negre.svg';

const basePaths = { ca: '/', es: '/es/', en: '/en/' } as const;

// Estructura de páginas incluyendo los submenús de "La Casa"
const pages = [
    { labels: { ca: 'Història', es: 'Historia', en: 'History' }, slugs: { ca: 'historia', es: 'historia', en: 'history' } },
    { 
        labels: { ca: 'La Casa', es: 'La Casa', en: 'The House' }, 
        slugs: { ca: 'la-casa', es: 'la-casa', en: 'the-house' },
        children: [
            { labels: { ca: 'Habitacions', es: 'Habitaciones', en: 'Rooms' }, slugs: { ca: 'habitacions', es: 'habitaciones', en: 'rooms' } },
            { labels: { ca: 'Zones Comuns', es: 'Zonas Comunes', en: 'Common Areas' }, slugs: { ca: 'zones-comuns', es: 'zonas-comunes', en: 'common-areas' } }
        ]
    },
    { labels: { ca: 'Entorn', es: 'Entorno', en: 'Surroundings' }, slugs: { ca: 'entorn', es: 'entorno', en: 'surroundings' } },
    { labels: { ca: 'Fotos', es: 'Fotos', en: 'Photos' }, slugs: { ca: 'fotos', es: 'fotos', en: 'photos' } },
    { labels: { ca: 'Contacte', es: 'Contacto', en: 'Contact' }, slugs: { ca: 'contacte', es: 'contacto', en: 'contact' } }

];

const currentItem = pages.find((item) => Object.values(item.slugs).includes(slug)) ?? null;

const buildPath = (targetLang: 'ca' | 'es' | 'en', itemSlug: string) => {
    const base = basePaths[targetLang];
    return itemSlug ? `${base}${itemSlug}/` : base;
};

const languageLinks = [
    { code: 'ca', label: 'CA' },
    { code: 'es', label: 'ES' },
    { code: 'en', label: 'EN' },
] as const;

const currentPath = currentItem ? currentItem.slugs[lang] : slug;
const isHome = !slug;
---

<header id="main-header" class:list={[
    'isolate z-50 w-full transition-colors duration-300',
    isHome ? 'absolute top-0 left-0 right-0 border-transparent bg-transparent text-white' : 'sticky top-0 border-b border-black/10 bg-[#f6efe4]/85 text-[#1f1a17] backdrop-blur-xl',
]}>
    <div class="mx-auto flex max-w-7xl items-center gap-4 px-4 py-3 lg:px-16">
        <a href={basePaths[lang]} class="flex items-center gap-3 px-2 py-1 transition-opacity hover:opacity-90 shrink-0">
            <img src={isHome ? logo.src : logoNegre.src} alt="Castell de Mejanell" class="h-14 md:h-16 w-auto" />
        </a>

        <nav class="hidden flex-1 items-center justify-center gap-8 xl:flex" aria-label="Principal Escritorio">
            {pages.map((item) => {
                const href = buildPath(lang, item.slugs[lang]);
                const isActive = currentPath === item.slugs[lang];
                const hasChildren = !!item.children;

                return (
                    <div class="relative group py-2">
                        {/* Enlace Principal */}
                        <a
                            href={hasChildren ? '#' : href}
                            class:list={[
                                'relative text-md font-semibold tracking-tight transition-colors duration-300 flex items-center gap-1',
                                isHome ? 'text-white/90 group-hover:text-[#f5d3a0]' : 'text-current group-hover:text-[#7a5a3d]',
                                isActive && (isHome ? 'text-[#f5d3a0]' : 'text-[#7a5a3d]'),
                            ]}
                        >
                            {item.labels[lang]}
                            
                            {hasChildren && (
                                <svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                </svg>
                            )}

                            {/* Subrayado dinámico */}
                            <span class:list={[
                                'absolute bottom-[-4px] left-0 h-[2px] w-full scale-x-0 transition-transform duration-300 origin-center group-hover:scale-x-100',
                                isHome ? 'bg-[#f5d3a0]' : 'bg-[#7a5a3d]'
                            ]}></span>
                        </a>

                        {/* Desplegable Dropdown Escritorio con mini iconos de rombo */}
                        {hasChildren && (
                            <div class:list={[
                                'absolute left-1/2 -translate-x-1/2 top-full mt-1 w-52 rounded-2xl p-2 shadow-xl border opacity-0 invisible translate-y-2 transition-all duration-300 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 z-50 pointer-events-auto',
                                isHome ? 'bg-black/85 border-white/10 backdrop-blur-md text-white' : 'bg-white border-black/5 text-[#1f1a17]'
                            ]}>
                                {item.children?.map((child) => {
                                    const childHref = buildPath(lang, child.slugs[lang]);
                                    return (
                                        <a 
                                            href={childHref} 
                                            class:list={[
                                                'flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium transition-all duration-200 group/sub',
                                                isHome ? 'hover:bg-white/10 hover:text-[#f5d3a0]' : 'hover:bg-[#f6efe4] hover:text-[#7a5a3d]'
                                            ]}
                                        >
                                            <span class:list={[
                                                'h-1.5 w-1.5 rotate-45 transform transition-all duration-300 ease-out shrink-0',
                                                isHome ? 'bg-white/40 group-hover/sub:bg-[#f5d3a0]' : 'bg-[#6b5f56]/40 group-hover/sub:bg-[#7a5a3d]',
                                                'group-hover/sub:translate-x-0.5 group-hover/sub:scale-110'
                                            ]}></span>
                                            <span>{child.labels[lang]}</span>
                                        </a>
                                    );
                                })}
                            </div>
                        )}
                    </div>
                );
            })}
        </nav>

        <div class="ml-auto flex items-center gap-4">
            
            <div class="relative group hidden md:block py-2">
                <button type="button" class:list={[
                    'flex items-center gap-1.5 text-xs font-bold tracking-[0.15em] transition-colors uppercase',
                    isHome ? 'text-white/90 hover:text-[#f5d3a0]' : 'text-[#4a413a] hover:text-[#7a5a3d]'
                ]}>
                    {lang}
                    <svg class="w-3 h-3 opacity-60 transition-transform duration-300 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>
                <div class:list={[
                    'absolute right-0 top-full mt-1 w-28 rounded-xl p-1.5 shadow-xl border opacity-0 invisible translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 z-50',
                    isHome ? 'bg-black/85 border-white/10 backdrop-blur-md text-white' : 'bg-white border-black/5 text-[#1f1a17]'
                ]}>
                    {languageLinks.map((item) => {
                        const targetItem = currentItem ?? pages[0];
                        const href = buildPath(item.code, targetItem.slugs[item.code]);
                        return (
                            <a 
                                href={href} 
                                class:list={[
                                    'flex items-center gap-2 rounded-lg px-3 py-1.5 text-xs font-bold tracking-wider transition-all duration-200 group/lang',
                                    item.code === lang ? (isHome ? 'bg-white/10 text-[#f5d3a0]' : 'bg-[#f6efe4] text-[#7a5a3d]') : (isHome ? 'text-white/60 hover:text-white' : 'text-[#6b5f56] hover:text-[#1f1a17]')
                                ]}
                            >
                                <span class:list={[
                                    'h-1 w-1 rotate-45 transform transition-all duration-200 shrink-0',
                                    item.code === lang ? (isHome ? 'bg-[#f5d3a0]' : 'bg-[#7a5a3d]') : 'bg-transparent group-hover/lang:bg-current'
                                ]}></span>
                                {item.label}
                            </a>
                        );
                    })}
                </div>
            </div>

            <a href={buildPath(lang, 'preus-i-ocupacio')} class:list={[
                'inline-flex items-center justify-center rounded-full text-xs px-4 py-2 sm:text-sm sm:px-5 sm:py-2.5 font-bold transition-all duration-200 hover:-translate-y-0.5 whitespace-nowrap shadow-sm',
                isHome ? 'border border-[#8A0E14] bg-[#8A0E14] text-white hover:bg-[#8A0E14]' : 'border border-[#1f1a17] bg-[#1f1a17] !text-[#f8f4ec] hover:bg-[#332c28]',
            ]}>
                Preus i ocupació
            </a>
            <button 
                type="button" 
                id="mobile-menu-button"
                class:list={[
                    'inline-flex items-center justify-center rounded-full border px-3.5 py-3 transition-colors xl:hidden',
                    isHome ? 'border-white/25 text-white hover:bg-white/10' : 'border-black/10 text-[#1f1a17] hover:bg-black/5',
                ]} 
                aria-label="Obrir Menú"
                aria-expanded="false"
            >
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>
    </div>
</header>

<div id="mobile-menu-overlay" class="fixed inset-0 z-[60] bg-black/40 backdrop-blur-sm opacity-0 invisible pointer-events-none"></div>

<div id="mobile-menu-panel" class="fixed top-0 right-0 z-[70] h-screen w-full max-w-[320px] bg-[#f6efe4] text-[#1f1a17] p-6 shadow-2xl overflow-y-auto" style="transform: translateX(100%);">
    <div class="flex items-center justify-between mb-8 pb-4 border-b border-black/5">
        <span class="text-sm font-bold uppercase tracking-[0.2em] text-[#7a5a3d]">Menú</span>
        <button type="button" id="mobile-menu-close" class="p-2 rounded-full hover:bg-black/5 text-[#1f1a17]" aria-label="Tancar Menú">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    <nav class="flex flex-col gap-1.5" aria-label="Principal Mòbil">
        {pages.map((item) => {
            const href = buildPath(lang, item.slugs[lang]);
            const isActive = currentPath === item.slugs[lang];
            const hasChildren = !!item.children;

            if (!hasChildren) {
                return (
                    <a href={href} class:list={[
                        'block rounded-xl px-4 py-3 text-base font-semibold transition-colors',
                        isActive ? 'bg-[#f0e6d6] text-[#7a5a3d]' : 'hover:bg-black/5 text-[#1f1a17]'
                    ]}>
                        {item.labels[lang]}
                    </a>
                );
            } else {
                return (
                    <div class="flex flex-col gap-1">
                        <span class="block px-4 py-3 text-base font-semibold text-[#1f1a17]">{item.labels[lang]}</span>
                        <div class="pl-4 flex flex-col gap-1.5 border-l-2 border-black/5 ml-1">
                            {item.children?.map((child) => {
                                const childHref = buildPath(lang, child.slugs[lang]);
                                const childActive = currentPath === child.slugs[lang];
                                return (
                                    <a href={childHref} class:list={[
                                        'block rounded-lg px-4 py-2.5 text-sm font-medium flex items-center gap-2.5 transition-colors',
                                        childActive ? 'text-[#7a5a3d]' : 'text-[#6b5f56] hover:text-[#1f1a17] hover:bg-black/5'
                                    ]}>
                                         <span class:list={[
                                            'h-1 w-1 rotate-45 transform shrink-0',
                                            childActive ? 'bg-[#7a5a3d]' : 'bg-[#6b5f56]/30',
                                        ]}></span>
                                        <span>{child.labels[lang]}</span>
                                    </a>
                                );
                            })}
                        </div>
                    </div>
                );
            }
        })}

        <div class="mt-6 pt-6 border-t border-black/5 flex gap-4 px-4">
            {languageLinks.map((item) => {
                const targetItem = currentItem ?? pages[0];
                const href = buildPath(item.code, targetItem.slugs[item.code]);
                return (
                    <a href={href} class:list={[
                        'text-xs font-extrabold tracking-widest uppercase transition-colors',
                        item.code === lang ? 'text-[#7a5a3d]' : 'text-[#6b5f56] hover:text-[#1f1a17]'
                    ]}>
                        {item.label}
                    </a>
                );
            })}
        </div>
    </nav>
</div>

<script>
    import { animate } from "motion";

    if (typeof window !== "undefined") {
        const openButton = document.getElementById('mobile-menu-button');
        const closeButton = document.getElementById('mobile-menu-close');
        const overlay = document.getElementById('mobile-menu-overlay');
        const panel = document.getElementById('mobile-menu-panel');
        const body = document.body;

        const toggleMenu = (open: boolean) => {
            if (!overlay || !panel || !openButton) return;

            if (open) {
                body.style.overflow = 'hidden'; 
                openButton.setAttribute('aria-expanded', 'true');
                
                overlay.style.visibility = 'visible';
                overlay.style.pointerEvents = 'auto';

                // Aplicamos 'as any' tanto a las propiedades como a las opciones
                animate(overlay, { opacity: [0, 1] } as any, { duration: 0.3, easing: 'ease-out' } as any);
                // Usar 'x' en lugar de 'transform' es más limpio y eficiente
                animate(panel, { x: ['100%', '0%'] } as any, { duration: 0.35, easing: 'ease-out' } as any);

            } else {
                body.style.overflow = ''; 
                openButton.setAttribute('aria-expanded', 'false');
                overlay.style.pointerEvents = 'none';

                animate(overlay, { opacity: [1, 0] } as any, { duration: 0.25, easing: 'ease-in' } as any);
                animate(panel, { x: ['0%', '100%'] } as any, { duration: 0.3, easing: 'ease-in' } as any)
                    .finished.then(() => {
                        if (openButton.getAttribute('aria-expanded') === 'false') {
                            overlay.style.visibility = 'hidden';
                        }
                    });
            }
        };

        openButton?.addEventListener('click', () => toggleMenu(true));
        closeButton?.addEventListener('click', () => toggleMenu(false));
        overlay?.addEventListener('click', () => toggleMenu(false));

        window.addEventListener('resize', () => {
            if (window.innerWidth >= 1280 && body.style.overflow === 'hidden') {
                toggleMenu(false);
            }
        });
    }
</script>