---
// src/components/Icono.astro
interface Props {
  viewBox?: string;
  class?: string;
}
const { viewBox = "0 0 24 24", class: className = "w-6 h-6" } = Astro.props;
---
<svg class={className} viewBox={viewBox} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <slot />
</svg>