---
export const lang = 'es';
export const slug = 'como-llegar';
import Layout from '../../layouts/Layout.astro';
---

<Layout lang={lang} slug={slug} title="Cómo llegar | Castell de Mejanell">
  <main class="mx-auto max-w-5xl px-4 py-10 lg:px-6">
    <h1 class="mb-6 text-3xl font-serif">Cómo llegar</h1>
    <p class="text-base text-[#6b5f56]">Indicaciones y mapa para llegar al Castell de Mejanell.</p>
    <p class="mt-6"><a href="/es/" class="text-sm underline">← Volver al inicio</a></p>
  </main>
</Layout>
