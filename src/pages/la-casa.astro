---
export const lang = 'ca';
export const slug = 'la-casa';
import Layout from '../layouts/Layout.astro';
---

<Layout lang={lang} slug={slug} title="La Casa | Castell de Mejanell">
  <main class="mx-auto max-w-5xl px-4 py-10 lg:px-6">
    <h1 class="mb-6 text-3xl font-serif">La Casa</h1>
    <p class="text-base text-[#6b5f56]">Descripció breu de la casa. Reemplaça per contingut definitiu.</p>
  </main>
</Layout>
