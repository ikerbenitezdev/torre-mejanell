---
export const lang = 'ca';
export const slug = 'historia';
import Layout from '../layouts/Layout.astro';
---

<Layout lang={lang} slug={slug} title="Història | Castell de Mejanell">
  <main class="mx-auto max-w-5xl px-4 py-10 lg:px-6">
    <h1 class="mb-6 text-3xl font-serif">Història</h1>
    <p class="text-base text-[#6b5f56]">Contingut d'exemple sobre la història del castell. Reemplaça per text real.</p>
    <p class="mt-6"><a href="/" class="text-sm underline">← Tornar a l'inici</a></p>
  </main>
</Layout>
