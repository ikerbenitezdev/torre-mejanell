---
export const lang = 'en';
export const slug = 'prices-and-occupancy';
import Layout from '../../layouts/Layout.astro';
---

<Layout lang={lang} slug={slug} title="Prices & Occupancy | Castell de Mejanell">
  <main class="mx-auto max-w-4xl px-4 py-10 lg:px-6">
    <h1 class="mb-6 text-3xl font-serif">Prices & Occupancy</h1>
    <p class="mb-4 text-base text-[#6b5f56]">Check availability and current prices via our booking widget.</p>

    <div class="bg-white w-full max-w-[685px]">
      <script type="text/javascript" src="https://www.escapadarural.com/widget-js/5c09509d3c4e0"></script>
      <iframe class="w-full h-[75vh] max-h-[800px]" src="https://www.escapadarural.com/widget-html/5c09509d3c4e0" scrolling="no" frameborder="0" marginheight="0" marginwidth="0"></iframe>
    </div>

    <p class="mt-6"><a href="/en/" class="text-sm underline">← Back to home</a></p>
  </main>
</Layout>
