---
export const lang = 'en';
export const slug = 'photos';
import Layout from '../../layouts/Layout.astro';
---

<Layout lang={lang} slug={slug} title="Photos | Castell de Mejanell">
  <main class="mx-auto max-w-5xl px-4 py-10 lg:px-6">
    <h1 class="mb-6 text-3xl font-serif">Photos</h1>
    <p class="text-base text-[#6b5f56]">Gallery of images of the castle and surroundings.</p>
    <p class="mt-6"><a href="/en/" class="text-sm underline">← Back to home</a></p>
  </main>
</Layout>
