---
export const lang = 'ca';
export const slug = 'localitzacio';
import Layout from '../layouts/Layout.astro';
---

<Layout lang={lang} slug={slug} title="Localització | Castell de Mejanell">
  <main class="mx-auto max-w-5xl px-4 py-10 lg:px-6">
    <h1 class="mb-6 text-3xl font-serif">Localització</h1>
    <p class="text-base text-[#6b5f56]">Indicacions i mapa per arribar al Castell de Mejanell.</p>
  </main>
</Layout>
