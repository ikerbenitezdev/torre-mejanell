---
export const lang = 'ca';
export const slug = 'entorn';
import Layout from '../layouts/Layout.astro';
---

<Layout lang={lang} slug={slug} title="Entorn | Castell de Mejanell">
  <main class="mx-auto max-w-5xl px-4 py-10 lg:px-6">
    <h1 class="mb-6 text-3xl font-serif">Entorn</h1>
    <p class="text-base text-[#6b5f56]">Informació sobre l'entorn i les activitats a prop. Reemplaça amb contingut real.</p>
  </main>
</Layout>
